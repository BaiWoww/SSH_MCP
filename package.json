{
  "name": "ssh-mcp",
  "version": "0.1.0",
  "description": "Local MCP server that exposes cloud servers to AI agents over SSH — file operations and command execution as if local.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ssh-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BaiWoww/SSH_MCP.git"
  },
  "keywords": [
    "ssh",
    "sftp",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "claude-desktop",
    "remote-server",
    "remote-files",
    "shell"
  ],
  "author": "BaiWoww",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ssh2": "^1.15.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/ssh2": "^1.15.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=18"
  }
}
